{
  "name": "inkly",
  "description": "Open-source, privacy-first writing assistant for Chrome/Edge/Brave — local grammar & spelling + optional AI.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "postinstall": "wxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tsconfig/svelte": "^5.0.8",
    "@vitest/ui": "^4.1.9",
    "@wxt-dev/module-svelte": "^2.0.4",
    "happy-dom": "^20.10.6",
    "svelte": "^5.53.7",
    "svelte-check": "^4.4.4",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "wxt": "^0.20.27"
  }
}
